---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<details class="toggle">
    <summary class="toggle-summary">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="toggle-arrow"
        >
            <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
        <span>{title}</span>
    </summary>
    <div class="toggle-content">
        <slot />
    </div>
</details>

<style>
    .toggle {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border-card);
        border-radius: 8px;
        margin: 1.5rem 0;
        overflow: hidden;
    }

    .toggle-summary {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.875rem 1.25rem;
        cursor: pointer;
        color: var(--text-primary);
        font-weight: 700;
        font-size: 0.9rem;
        list-style: none;
    }

    .toggle-summary::-webkit-details-marker {
        display: none;
    }

    .toggle-arrow {
        flex-shrink: 0;
        transition: transform 0.2s ease;
    }

    .toggle[open] .toggle-arrow {
        transform: rotate(90deg);
    }

    .toggle-content {
        padding: 0 1.25rem 1.25rem;
        color: var(--text-primary);
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .toggle-content :global(p) {
        margin: 0;
    }

    .toggle-content :global(p:not(:last-child)) {
        margin-bottom: 0.75rem;
    }
</style>
