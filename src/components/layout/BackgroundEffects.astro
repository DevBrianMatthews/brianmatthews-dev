---
interface Props {
    showDots?: boolean;
}

const { showDots = true } = Astro.props;
---

<div class="orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
</div>

{showDots && <div class="dots" />}

<style>
    .orbs {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
    }

    .orb-1 {
        width: 280px;
        height: 280px;
        top: -80px;
        right: -80px;
        opacity: 0.6;
        animation: float1 7s ease-in-out infinite alternate;
    }

    .orb-2 {
        width: 220px;
        height: 220px;
        top: 100px;
        right: 20px;
        opacity: 0.5;
        animation: float2 10s ease-in-out infinite alternate;
    }

    @keyframes float1 {
        0% {
            transform: translate(0px, 0px) scale(1);
            background: radial-gradient(circle, #6013de, #0a1121);
        }
        33% {
            transform: translate(-40px, 30px) scale(1.15);
            background: radial-gradient(circle, #8020ff, #0a1121);
        }
        66% {
            transform: translate(20px, -30px) scale(0.9);
            background: radial-gradient(circle, #5617a8, #0a1121);
        }
        100% {
            transform: translate(-20px, 40px) scale(1.1);
            background: radial-gradient(circle, #6013de, #0a1121);
        }
    }

    @keyframes float2 {
        0% {
            transform: translate(0px, 0px) scale(1);
            background: radial-gradient(circle, #1324de, #0a1121);
        }
        33% {
            transform: translate(30px, -40px) scale(1.2);
            background: radial-gradient(circle, #8613de, #0a1121);
        }
        66% {
            transform: translate(-30px, 20px) scale(0.85);
            background: radial-gradient(circle, #6013de, #0a1121);
        }
        100% {
            transform: translate(40px, -20px) scale(1.05);
            background: radial-gradient(circle, #8613de, #0a1121);
        }
    }

    .dots {
        position: fixed;
        inset: 0;
        background-image: radial-gradient(circle, #3a3f5c 1px, transparent 1px);
        background-size: 24px 24px;
        opacity: 0.5;
        pointer-events: none;
        z-index: 0;
    }
</style>
