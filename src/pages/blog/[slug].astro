---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import BackgroundEffects from "../../components/layout/BackgroundEffects.astro";
import Math from "../../components/blog/Math";
import Callout from "../../components/blog/Callout.astro";
import { getCollection, render } from "astro:content";
import Toggle from "../../components/blog/Toggle.astro";

export async function getStaticPaths() {
    const posts = await getCollection(
        "blog",
        ({ data }) => data.draft !== true,
    );

    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date | undefined): string {
    if (!date) return "Sin fecha de publicación";

    return new Date(date).toLocaleDateString("en-US", {
        month: "short",
        day: "2-digit",
        year: "numeric",
    });
}
---

<BaseLayout title={`${post.data.title} - Brian Matthews`}>
    <Header />
    <BackgroundEffects />
    <main>
        <a href="/blog" class="back-btn">&#8249;</a>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-date">Created — {formatDate(post.data.date)}</p>

        <div class="post-tags">
            {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <article class="post-content">
            <Content components={{ Math, Callout, Toggle }} />
        </article>
    </main>
</BaseLayout>

<style>
    main {
        position: relative;
        z-index: 1;
        padding: 6rem 1.25rem 3rem;
        max-width: 680px;
        margin: 0 auto;
        font-family: var(--font-mono);
    }
    .back-btn {
        display: inline-block;
        color: var(--text-primary);
        font-size: 2rem;
        line-height: 1;
        text-decoration: none;
        margin-bottom: 1.5rem;
        cursor: pointer;
    }

    .post-title {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 0.75rem;
    }

    .post-date {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    .post-tags {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .tag {
        font-size: 0.75rem;
        background: #4638d1;
        color: white;
        padding: 0.25rem 0.625rem;
        border-radius: 5px;
    }

    .post-content {
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--text-primary);
    }
    .post-content :global(h1) {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 2rem 0 1rem;
        color: var(--text-primary);
    }

    .post-content :global(h2) {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 1.75rem 0 0.875rem;
        color: var(--text-primary);
    }

    .post-content :global(h3) {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 1.5rem 0 0.75rem;
        color: var(--text-primary);
    }

    .post-content :global(p) {
        margin-bottom: 1.25rem;
    }

    .post-content :global(strong) {
        font-weight: 700;
    }

    .post-content :global(em) {
        font-style: italic;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px solid var(--border-card);
        margin: 2rem 0;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
        margin: 1rem 0 1.25rem;
        padding-left: 1.5rem;
    }

    .post-content :global(li) {
        margin-bottom: 0.5rem;
    }

    .post-content :global(.blog-image) {
        display: block;
        margin: 1.5rem auto;
        border-radius: 8px;
    }

    .post-content :global(blockquote) {
        border-left: 3px solid #4638d1;
        padding-left: 1rem;
        margin: 1.25rem 0;
        color: var(--text-muted);
    }

    .post-content :global(code) {
        background: var(--bg-card);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.85rem;
    }

    .post-content :global(.code-wrapper) {
        position: relative;
        margin: 1.5rem 0;
    }

    .post-content :global(.code-language-label) {
        position: absolute;
        top: 1rem;
        right: 3.75rem;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-family: var(--font-mono);
        z-index: 2;
        pointer-events: none;
    }

    .post-content :global(pre.astro-code) {
        position: relative !important;
        background-color: transparent !important;
        background-image:
            linear-gradient(70deg, #101118, #0e1024),
            linear-gradient(70deg, #36b2f0, #c01acc) !important;
        background-origin: border-box;
        background-clip: padding-box, border-box;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 2.5rem 1.25rem 1.25rem;
        overflow-x: auto;
        margin: 0;
        box-shadow: 0 0 17px 6px rgba(54, 50, 255, 0.15);
        animation: borderShift 6s linear infinite;
    }

    .post-content :global(.code-wrapper::before) {
        content: "";
        position: absolute;
        top: 1rem;
        left: 1.25rem;
        width: 0.6rem;
        height: 0.6rem;
        border-radius: 50%;
        background: #ff5f56;
        box-shadow:
            1rem 0 0 #ffbd2e,
            2rem 0 0 #27c93f;
        z-index: 2;
    }

    .post-content :global(pre.astro-code code) {
        background: none !important;
        padding: 0;
        font-size: 0.85rem;
        line-height: 1.7;
    }

    .post-content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.875rem;
    }

    .post-content :global(th) {
        background: var(--bg-card);
        color: var(--text-primary);
        font-weight: 700;
        padding: 0.75rem 1rem;
        text-align: left;
        border-bottom: 2px solid #4638d1;
    }

    .post-content :global(td) {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border-card);
        color: var(--text-primary);
    }

    .post-content :global(tr:hover td) {
        background: rgba(70, 56, 209, 0.05);
    }

    .post-content :global(.copy-code-btn) {
        position: absolute;
        top: 1rem;
        right: 1.25rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid #5b6377;
        border-radius: 6px;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        cursor: pointer;
        z-index: 3;
        transition:
            background 0.15s ease,
            color 0.15s ease;
    }

    .post-content :global(.copy-code-btn:hover) {
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-primary);
    }

    .post-content :global(.icon-check) {
        display: none;
    }

    .post-content :global(.copy-code-btn.copied .icon-copy) {
        display: none;
    }

    .post-content :global(.copy-code-btn.copied .icon-check) {
        display: block;
        color: #27c93f;
    }

    @keyframes borderShift {
        0% {
            background-position:
                0% 0%,
                0% 0%;
        }
        50% {
            background-position:
                0% 0%,
                100% 100%;
        }
        100% {
            background-position:
                0% 0%,
                0% 0%;
        }
    }
</style>

<script>
    document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".copy-code-btn");
        if (!btn) return;

        const wrapper = btn.closest(".code-wrapper");
        const code = wrapper?.querySelector("code");
        if (!code) return;

        const text = code.textContent || "";

        navigator.clipboard.writeText(text).then(() => {
            btn.classList.add("copied");
            setTimeout(() => {
                btn.classList.remove("copied");
            }, 2000);
        });
    });
</script>
