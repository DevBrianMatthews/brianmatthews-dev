---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
---

<BaseLayout title="Brian Matthews">
    <Header showMenu={false} />

    <div class="orbs">
        <div class="orb orb-blue"></div>
        <div class="orb orb-purple"></div>
    </div>

    <main>
        <div class="hero-image">
            <img src="/vector.svg" class="vector" alt="" />
            <img src="/Contruction.png" class="character" alt="Character" />
        </div>

        <div class="text-container">
            <h1 class="title-white">Sitio Web</h1>
            <h1 class="title-gradient">En construción</h1>
        </div>

        <a href="/blog" class="cta-btn">Conoce mi blog</a>
    </main>
</BaseLayout>

<style>
    .orbs {
        position: fixed;
        top: 0;
        right: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
    }

    .orb-blue {
        width: 250px;
        height: 250px;
        top: -60px;
        right: -60px;
        background: radial-gradient(circle, #1370de, #0a1121);
        opacity: 0.4;
        animation: moveBlue 10s ease-in-out infinite alternate;
    }

    .orb-purple {
        width: 180px;
        height: 180px;
        top: -20px;
        right: 80px;
        background: radial-gradient(circle, #6013de, #0a1121);
        opacity: 0.6;
        animation: movePurple 12s ease-in-out infinite alternate;
    }

    @keyframes moveBlue {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        50% {
            transform: translate(-15px, 20px) scale(1.1);
        }
        100% {
            transform: translate(10px, -15px) scale(0.95);
        }
    }

    @keyframes movePurple {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        50% {
            transform: translate(15px, 25px) scale(1.15);
        }
        100% {
            transform: translate(-10px, -20px) scale(0.9);
        }
    }

    main {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 80px);
        padding: 2rem 1.5rem;
        gap: 2rem;
        font-family: var(--font-inter);
    }

    .hero-image {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .vector {
        position: absolute;
        border: none;
        z-index: 0;
        width: 250px;
        height: 250px;
    }

    .character {
        position: relative;
        z-index: 2;
        width: 280px;
        height: 280px;
    }

    .text-container {
        text-align: center;
        line-height: 1.2;
        margin-top: 1.5rem;
    }

    .title-white {
        font-size: 2.25rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .title-gradient {
        font-size: 2.25rem;
        font-weight: 700;
        background: linear-gradient(30deg, #6013de, #3ebaff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .cta-btn {
        display: block;
        width: 100%;
        max-width: 320px;
        padding: 1rem;
        text-align: center;
        background: linear-gradient(30deg, #6013de, #3ebaff);
        color: white;
        font-family: var(--font-inter);
        font-size: 1rem;
        font-weight: 500;
        text-decoration: none;
        border-radius: 12px;
    }
</style>
